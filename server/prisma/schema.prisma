// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  isMember  Boolean  @default(false)
  createdAt DateTime @default(now())
  bookshelf Bookshelf[]
  payments  Payment[]
  chatRooms  ChatRoom[]
  level     Int      @default(1)
}

enum BookStatus {
  BEFORE
  READING
  DONE
}

model Book {
  id        Int         @id @default(autoincrement())
  isbn      String      @unique
  title     String
  author    String
  imageUrl  String
  description String
  createdAt DateTime    @default(now())
  bookshelf Bookshelf[]
}

model Bookshelf {
  id        Int        @id @default(autoincrement())
  userId    Int
  bookId    Int
  status    BookStatus
  createdAt DateTime   @default(now())

  comment   String?    // 한줄평
  phrase   String?    // 인상깊은 문장
  emotion   String?    // 감정
  startDate DateTime?  // 시작 날짜
  endDate   DateTime?  // 완료 날짜
  intent    String?
  sub    String?

  aiComment String?
  aiTags    String[]

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model BookEmbedding {
  id        Int    @id @default(autoincrement())
  userId    Int
  bookId    Int
  embedding Unsupported("vector(3072)")
  createdAt DateTime @default(now())
}

model Payment {
  id            Int      @id @default(autoincrement())
  orderId       String   @unique
  paymentKey    String?  @unique
  amount        Int
  status        String   // READY, DONE, FAIL
  orderName     String
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatRoom {
  id        Int           @id @default(autoincrement())
  userId    Int
  title     String        @default("새 채팅")
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  roomId    Int
  role      String
  content   String
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id] ,onDelete: Cascade)
}